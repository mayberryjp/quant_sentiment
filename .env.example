# PostgreSQL connection (required in production). SQLAlchemy + psycopg3 DSN.
DATABASE_URL=postgresql+psycopg://sentiment:sentiment@localhost:5432/sentiment

# API server
API_LISTEN_ADDRESS=0.0.0.0
API_PORT=8017

# Tuning knobs (QUANT_SENTIMENT_ prefix)
QUANT_SENTIMENT_NEUTRAL_BAND=20
QUANT_SENTIMENT_DEFAULT_PAGE_SIZE=25
QUANT_SENTIMENT_MAX_PAGE_SIZE=100
QUANT_SENTIMENT_DEFAULT_WINDOW=1d
QUANT_SENTIMENT_MAX_WINDOW=90d
